# ============================================================================
# Required — zarl will refuse to start without these
# ============================================================================

# OpenAI-compatible chat-completions endpoint. Anything that speaks
# /v1/chat/completions works:
#   - llama.cpp server (this repo's docker-compose 'llm' profile spawns one
#     on :8081 — see docs/running.md)
#   - Ollama: http://localhost:11434/v1 with any pulled model
#   - Hosted: OpenRouter, OpenAI, Groq, Together, Fireworks, Anthropic via
#     a proxy that exposes the OpenAI shape
CHAT_URL=http://localhost:8081/v1
CHAT_MODEL=qwen3.6-35b-a3b

# Embeddings via Ollama. Pull the model once: `ollama pull nomic-embed-text`
# (zarl never calls Ollama for chat — only embeddings).
EMBED_URL=http://localhost:11434/v1
EMBED_MODEL=nomic-embed-text

# Database. Matches the docker-compose 'dolt' service on :3307.
DOLT_DSN=root:@tcp(localhost:3307)/zarl?parseTime=true

# Single root for ALL pretrained model assets — STT, TTS, face,
# and the GGUF weights llama-server loads. Subpaths underneath are
# fixed (whisper-small-en/, kokoro-en-v0_19/, dlib/, plus your GGUFs);
# unpack each upstream tarball at the root and you're done.
# docker-compose mounts this into the llama-server container at /models.
MODELS_DIR=./deploy/models

# ============================================================================
# Optional
# ============================================================================

# Separate llama-server for the autonomous taskrunner. Defaults to
# CHAT_URL / CHAT_MODEL when unset. Useful when you want the
# conversation path on a fast local model and the taskrunner on a beefier
# remote one (or vice versa).
# TASK_CHAT_URL=
# TASK_CHAT_MODEL=

# Spotify, Obsidian, MCP servers, and other tool providers are configured
# at runtime via /admin → Tools, NOT via environment. Skip them on first
# boot — zarl runs fine without any of them configured.
