# zarlcode .env example.
#
# The TUI settings pane is the primary configuration surface. Use `.env` only
# for bootstrap values, CI/headless runs, local development, and secrets you do
# not want to persist in ~/.zarlcode/state.db.
#
# Load with:
#
#   zarlcode -env /path/to/.env
#
# Values in this file are process environment fallbacks. Persisted workspace or
# global settings normally win where a setting exists.

# --- Provider bootstrap ---------------------------------------------

# Default model used before a model is saved in settings. zarlcode defaults to
# provider `llamacpp` and model `local` when unset.
# ZARLCODE_MODEL=local

# One-off OpenAI-compatible endpoint/key override for the fallback provider.
# Prefer the Providers settings pane for durable custom providers and keys.
# ZARLCODE_BASE_URL=http://127.0.0.1:8081/v1
# ZARLCODE_API_KEY=sk-local-or-hosted-key

# Provider-specific API key fallbacks. Prefer `zarlcode keys set <provider>` or
# the Providers settings pane for durable encrypted credentials.
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# DEEPSEEK_API_KEY=sk-...
# GEMINI_API_KEY=...
# GOOGLE_API_KEY=...
# LLM_API_KEY=...

# Provider-specific base URL fallbacks for built-in providers.
# LLAMACPP_BASE_URL=http://127.0.0.1:8081/v1
# OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Google Vertex uses Application Default Credentials plus normal Google Cloud
# environment variables.
# GOOGLE_CLOUD_PROJECT=my-project
# GOOGLE_CLOUD_LOCATION=us-central1

# --- Integrations ----------------------------------------------------

# web_search endpoint fallback. The settings pane key is `search_searxng_url`.
# SEARXNG_URL=http://127.0.0.1:8080

# Theme fallback used before a theme is saved in settings.
# ZARLCODE_THEME=catppuccin-mocha

# External editor fallback when the `editor` setting is unset.
# ZARLCODE_EDITOR=code -w
# VISUAL=vim
# EDITOR=vi

# --- Vault / headless automation ------------------------------------

# Unlock encrypted provider credentials non-interactively. Useful for CI or
# headless runs; avoid committing real values.
# ZARLCODE_KEY=base64-encoded-32-byte-key
# ZARLCODE_PASSPHRASE=correct horse battery staple

# --- Emergency / development overrides ------------------------------

# Explicitly override the persisted sandbox setting for this process. Unset means
# use settings. off/0/false/no disables; any other value enables.
# ZARLCODE_SANDBOX=off

# Extra sandbox grants for unusual local toolchains. Colon-separated paths.
# ZARLCODE_SANDBOX_EXTRA_RO=/opt/toolchain
# ZARLCODE_SANDBOX_EXTRA_RW=/tmp/build-cache

# GitHub token used only by `zarlcode upgrade` release downloads when you need a
# higher API rate limit or private fork access.
# GITHUB_TOKEN=ghp_...

# Disable colour output for tools that respect https://no-color.org/.
# NO_COLOR=1
