# hnupvote demo configuration template. Copy to .env and fill in:
#   cp examples/hnupvote/.env.example examples/hnupvote/.env
# .env is gitignored; this template is committed as the reference.

# --- Hacker News account (used by the hn_login tool) ---
HN_USER=
HN_PASS=

# --- LLM backend ---
# openai-codex reuses zarlcode's vault: the ChatGPT OAuth credential you
# logged in with (`zarlcode keys oauth openai-codex`) drives the agent and
# auto-refreshes. No token goes in this file — it stays encrypted in
# ~/.zarlcode/state.db. Only the model + effort are configured here.
LLM_PROVIDER=openai-codex
LLM_MODEL=gpt-5.5
CODEX_REASONING_EFFORT=high

# --- Alternative backend (only used when LLM_PROVIDER is NOT openai-codex) ---
# An OpenAI-compatible provider via a static API key.
#OPENAI_API_KEY=
#LLM_BASE_URL=http://localhost:8081/v1
